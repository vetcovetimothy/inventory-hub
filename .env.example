# ─── Acumatica ───
# Base URL for your Acumatica instance (no trailing slash)
ACUMATICA_BASE_URL=https://vetcove.acumatica.com

# OData endpoint paths (these are appended to the base URL)
ACUMATICA_ODATA_PREFIX=/(W(89))/odata/VetCove

# ─── Gmail OAuth2 ───
# Create these at https://console.cloud.google.com → APIs & Services → Credentials
# 1. Create an OAuth 2.0 Client ID (type: Web application)
# 2. Add http://localhost:3000/api/gmail-callback as a redirect URI
# 3. Enable the Gmail API in your project
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/gmail-callback

# After running the one-time auth flow, paste the refresh token here:
GOOGLE_REFRESH_TOKEN=

# ─── App ───
# A random secret for encrypting session data (generate with: openssl rand -hex 32)
APP_SECRET=change-me-to-a-random-string
